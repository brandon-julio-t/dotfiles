{
  "diff_view_style": "split",
  "buffer_font_weight": 100.0,
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "icon_theme": "Pierre Icons (Complete)",
  "agent_servers": {
    },
  "edit_predictions": {
    "disabled_globs": [],
  },
  "colorize_brackets": true,
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  "cli_default_open_behavior": "new_window",
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "thinking_display": "preview",
    "flexible": false,
    "show_turn_stats": true,
    "play_sound_when_agent_done": "always",
    "expand_edit_card": false,
  },
  "format_on_save": "on",
  "autosave": "on_window_change",
  "theme": "Pierre Dark Soft",
  "ui_font_family": ".SystemUIFont",
  "buffer_font_family": "SF Mono",
  "ui_font_size": 14.0,
  "buffer_font_size": 12.0,
  "agent_buffer_font_size": 12.0,
  "agent_ui_font_size": 14.0,
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "git_panel": {
    "dock": "right",
    "show_count_badge": false,
    "sort_by_path": false,
    "collapse_untracked_diff": false,
    "status_style": "label_color",
    "file_icons": true,
    "tree_view": true,
  },
  "tabs": {
    "file_icons": true,
  },
  "project_panel": {
    "dock": "right",
    "git_status_indicator": false,
  },
  "terminal": {
    "font_weight": 100.0,
    "font_size": 12.0,
    "minimum_contrast": 0,
    "cursor_shape": "bar",
    "shell": {
      "with_arguments": {
        "program": "/opt/homebrew/bin/nu",
        "args": ["-l"],
      },
    },
  },
}
