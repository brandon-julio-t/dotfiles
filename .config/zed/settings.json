// Zed settings
//
// For information on how to configure Zed, see the Zed https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "ssh_connections": [
    {
      "host": "openclaw-server",
      "args": [],
      "projects": [
        {
          "paths": ["/home/ec2-user"],
        },
      ],
    },
  ],
  "format_on_save": "on",
  "autosave": "on_window_change",
  "icon_theme": "Material Icon Theme",
  "theme": "Vague",
  "ui_font_family": "SF Mono",
  "buffer_font_family": "SF Mono",
  "ui_font_size": 12,
  "buffer_font_size": 12,
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "git_panel": {
    "tree_view": true,
  },
  "tabs": {
    "file_icons": true,
    "show_diagnostics": "all",
  },
  "terminal": {
    "minimum_contrast": 0,
    "font_family": "GeistMono Nerd Font",
    "cursor_shape": "bar",
    "shell": {
      "with_arguments": {
        "program": "/opt/homebrew/bin/nu",
        "args": ["-l"],
      },
    },
  },
}
