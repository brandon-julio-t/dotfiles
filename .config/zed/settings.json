// Zed settings
//
// For information on how to configure Zed, see the Zed https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "cli_default_open_behavior": "new_window",
  "agent": {
    "dock": "right",
    "thinking_display": "preview",
    "flexible": false,
    "show_turn_stats": true,
    "expand_edit_card": false,
    "expand_terminal_card": false,
    "play_sound_when_agent_done": "always",
  },
  "agent_servers": {
    "opencode": {
      "favorite_config_option_values": {
        "model": ["openai/gpt-5.4-fast/xhigh"],
      },
      "default_config_options": {
        "model": "openai/gpt-5.4-fast/xhigh",
      },
      "type": "registry",
    },
    "codex-acp": {
      "default_config_options": {
        "reasoning_effort": "xhigh",
        "model": "gpt-5.4",
      },
      "type": "registry",
    },
  },
  "format_on_save": "on",
  "autosave": "on_window_change",
  "icon_theme": "Material Icon Theme",
  "theme": "Vague",
  "ui_font_family": "SF Mono",
  "buffer_font_family": "SF Mono",
  "ui_font_size": 12.0,
  "buffer_font_size": 12.0,
  "agent_buffer_font_size": 12.0,
  "agent_ui_font_size": 12.0,
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "tabs": {
    "file_icons": true,
    "show_diagnostics": "all",
  },
  "project_panel": {
    "dock": "left",
    "diagnostic_badges": true,
  },
  "terminal": {
    "dock": "right",
    "minimum_contrast": 0,
    "font_family": "GeistMono Nerd Font",
    "cursor_shape": "bar",
    "shell": {
      "with_arguments": {
        "program": "/opt/homebrew/bin/nu",
        "args": ["-l"],
      },
    },
  },
}
