// Zed settings
//
// For information on how to configure Zed, see the Zed https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_diagnostics": "all",
  },
  "scrollbar": {
    "show": "system",
  },
  "format_on_save": "on",
  "git_panel": {
    "tree_view": true,
  },
  "autosave": "on_window_change",
  "icon_theme": "Catppuccin Mocha",
  "theme": "Vague",
  "theme_overrides": {
    "Catppuccin Latte": {},
    "Catppuccin Frappé": {},
    "Catppuccin Macchiato": {},
    "Catppuccin Mocha": {
      "border.variant": "#B4BEFE52",
    },
  },
  "ui_font_family": "SF Mono",
  "buffer_font_family": "SF Mono",
  "ui_font_size": 12,
  "buffer_font_size": 12,
  "edit_predictions": {
    "provider": "mercury",
    "mode": "eager",
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
    },
  },
  "terminal": {
    "minimum_contrast": 0,
    "font_family": "GeistMono Nerd Font",
    "dock": "right",
    "cursor_shape": "bar",
    "shell": {
      "with_arguments": {
        "program": "/opt/homebrew/bin/nu",
        "args": ["-l"],
      },
    },
  },
}
