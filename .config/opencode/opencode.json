{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "CONTRIBUTING.md",
    "CLAUDE.md",
    "docs/guidelines.md",
    ".cursor/rules/*.md"
  ],
  "mcp": {
    "Notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["bunx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
      "enabled": false
    }
  }
}
