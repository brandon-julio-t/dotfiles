{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5-fast",
  "agent": {
    "build": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    },
    "plan": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    },
    "general": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    },
    "explore": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    }
  },
  "permission": {
    "*": "allow"
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["bunx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
      "enabled": false
    }
  }
}
