{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "background": "#1d1f21",
    "line": "#282a2e",
    "selection": "#373b41",
    "window": "#4d5057",
    "comment": "#969896",
    "foreground": "#c5c8c6",
    "red": "#cc6666",
    "orange": "#de935f",
    "yellow": "#f0c674",
    "green": "#b5bd68",
    "aqua": "#8abeb7",
    "blue": "#81a2be",
    "purple": "#b294bb"
  },
  "theme": {
    "primary": { "dark": "blue", "light": "blue" },
    "secondary": { "dark": "purple", "light": "purple" },
    "accent": { "dark": "orange", "light": "orange" },
    "error": { "dark": "red", "light": "red" },
    "warning": { "dark": "yellow", "light": "yellow" },
    "success": { "dark": "green", "light": "green" },
    "info": { "dark": "aqua", "light": "aqua" },
    "text": { "dark": "foreground", "light": "foreground" },
    "textMuted": { "dark": "comment", "light": "comment" },
    "background": { "dark": "background", "light": "background" },
    "backgroundPanel": { "dark": "line", "light": "line" },
    "backgroundElement": { "dark": "selection", "light": "selection" },
    "border": { "dark": "window", "light": "window" },
    "borderActive": { "dark": "blue", "light": "blue" },
    "borderSubtle": { "dark": "selection", "light": "selection" },
    "diffAdded": { "dark": "green", "light": "green" },
    "diffRemoved": { "dark": "red", "light": "red" },
    "diffContext": { "dark": "comment", "light": "comment" },
    "diffHunkHeader": { "dark": "yellow", "light": "yellow" },
    "diffHighlightAdded": { "dark": "green", "light": "green" },
    "diffHighlightRemoved": { "dark": "red", "light": "red" },
    "diffAddedBg": { "dark": "line", "light": "line" },
    "diffRemovedBg": { "dark": "line", "light": "line" },
    "diffContextBg": { "dark": "line", "light": "line" },
    "diffLineNumber": { "dark": "comment", "light": "comment" },
    "diffAddedLineNumberBg": { "dark": "line", "light": "line" },
    "diffRemovedLineNumberBg": { "dark": "line", "light": "line" },
    "markdownText": { "dark": "foreground", "light": "foreground" },
    "markdownHeading": { "dark": "blue", "light": "blue" },
    "markdownLink": { "dark": "aqua", "light": "aqua" },
    "markdownLinkText": { "dark": "blue", "light": "blue" },
    "markdownCode": { "dark": "green", "light": "green" },
    "markdownBlockQuote": { "dark": "comment", "light": "comment" },
    "markdownEmph": { "dark": "yellow", "light": "yellow" },
    "markdownStrong": { "dark": "purple", "light": "purple" },
    "markdownHorizontalRule": { "dark": "comment", "light": "comment" },
    "markdownListItem": { "dark": "blue", "light": "blue" },
    "markdownListEnumeration": { "dark": "aqua", "light": "aqua" },
    "markdownImage": { "dark": "aqua", "light": "aqua" },
    "markdownImageText": { "dark": "blue", "light": "blue" },
    "markdownCodeBlock": { "dark": "foreground", "light": "foreground" },
    "syntaxComment": { "dark": "comment", "light": "comment" },
    "syntaxKeyword": { "dark": "purple", "light": "purple" },
    "syntaxFunction": { "dark": "blue", "light": "blue" },
    "syntaxVariable": { "dark": "foreground", "light": "foreground" },
    "syntaxString": { "dark": "green", "light": "green" },
    "syntaxNumber": { "dark": "orange", "light": "orange" },
    "syntaxType": { "dark": "yellow", "light": "yellow" },
    "syntaxOperator": { "dark": "aqua", "light": "aqua" },
    "syntaxPunctuation": { "dark": "foreground", "light": "foreground" }
  }
}
